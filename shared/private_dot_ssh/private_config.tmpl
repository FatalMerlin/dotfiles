# ~/.ssh/config — generic skeleton (managed by chezmoi).
# Host inventories live OUTSIDE the dotfiles, in per-audience repos that drop
# files into ~/.ssh/config.d/*.conf. OpenSSH >= 7.3 silently ignores an Include
# whose glob matches nothing, so this is safe on any machine (personal, a friend's).

# Audience host inventories (work / arkanis / personal — each owned by its own repo).
Include ~/.ssh/config.d/*.conf

# 1Password-managed per-item IdentityFile mappings (auto-generated by the 1Password
# app; not managed here). Absent on machines without 1Password — harmless if missing.
Include ~/.ssh/1Password/config

# Global defaults last, so any host-specific setting above takes precedence
# (ssh uses the first value obtained for each parameter).
Host *
    Compression yes
{{- /* Windows: intentionally NO IdentityAgent. ssh's built-in default is the pipe
       \\.\pipe\openssh-ssh-agent (1Password owns it — the Windows ssh-agent service is
       disabled). An EXPLICIT value is mangled by ssh_config backslash parsing
       (\\.\pipe collapses to \.\pipe), an invalid path that breaks agent auth. */}}
{{- if eq .chezmoi.os "darwin" }}
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else if eq .chezmoi.os "linux" }}
    IdentityAgent ~/.1password/agent.sock
{{- end }}
