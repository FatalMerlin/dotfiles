{{/* prototype/windows/run_onchange_resolve-deps.ps1.tmpl — apply-time resolver.
     chezmoi renders this (manifest + private data in scope) and runs the result
     via the ps1 interpreter (pwsh). Regenerates deps.ps1 + install-plan.ps1
     whenever the manifest changes: the whole manifest is baked in below, so any
     edit changes this file's rendered content -> run_onchange re-fires.

     PowerShell mirror of run_onchange_resolve-deps.sh.tmpl — same TWO outputs,
     same gate/check/env/path/aliases/completion/setup semantics, same Kahn
     topo-sort for the install plan. Windows-only deviations are noted inline
     (no dpkg/file check variants; no wsl gate branches; aliases become global
     function closures because PS aliases can't carry arguments). */}}
# manifest-hash: {{ .packages | toJson | sha256sum }}
# GENERATED-RESOLVER — do not hand-edit the emitted deps.ps1.
$OutDir = if ($env:DEPS_OUT_DIR) { $env:DEPS_OUT_DIR } else { Join-Path $HOME '.config/dotfiles' }
$Deps = Join-Path $OutDir 'deps.ps1'
$Plan = Join-Path $OutDir 'install-plan.ps1'
New-Item -ItemType Directory -Force -Path $OutDir | Out-Null

# ---- Output 1 — deps.ps1 (dot-sourced startup artifact) ---------------------
$lines = [System.Collections.Generic.List[string]]::new()
$lines.Add('# GENERATED by run_onchange_resolve-deps — do not edit. Dot-source only.')
$lines.Add("Import-Module (Join-Path `$HOME 'Documents/PowerShell/dotfiles/lib/Core.psm1') -Force")
$lines.Add("`$__hooks = Join-Path `$HOME 'Documents/PowerShell/dotfiles/hooks/SetupHooks.psm1'")
$lines.Add('if (Test-Path $__hooks) { Import-Module $__hooks -Force }')
$lines.Add('dep_reset_missing')
$lines.Add('')
{{- range $mgr, $pkgs := .packages }}
{{-   range $name, $cfg := $pkgs }}
$lines.Add('# ---- {{ $name }} ({{ $mgr }}) ----')
{{-     $check := index $cfg "check" | default "command" }}
{{- /* presence predicate: default -> `have <name>`; `custom:<expr>` -> raw
       <expr> as a PS boolean. No dpkg/file variants on Windows. */ -}}
{{-     $pred := printf "have %s" $name }}
{{-     if hasPrefix "custom:" $check }}{{ $pred = trimPrefix "custom:" $check }}{{ end }}
{{- /* gate is an OUTER skip-wrapper, NOT `gate && pred`: when the gate excludes
       this machine the whole guard (incl. dep_mark_missing) is skipped, so a
       gated-out tool is invisible — never reported missing / offered for install.
       Only the hostSuffix map gate is supported on Windows (the unix !wsl/wsl
       branches are Linux-only and intentionally omitted). */ -}}
{{-     $gate := index $cfg "gate" | default "" }}
{{-     $gated := false }}
{{-     if and (kindIs "map" $gate) (hasKey $gate "hostSuffix") }}
{{-       $gated = true }}
$lines.Add('if ([System.Net.Dns]::GetHostName() -like "*{{ includeTemplate "resolveRef.tmpl" (dict "ref" (index $gate "hostSuffix") "data" $) }}") {')
{{-     end }}
$lines.Add('if ({{ $pred }}) {')
{{- /* env value is either a plain string (always exported) or a map
       { value, feature } — a per-host FEATURE-gated export: emitted only when
       @features.<feature> resolves "true" for this host (resolved at apply-time).
       The tool itself stays tracked everywhere; only the work-specific env toggles
       per host. */ -}}
{{-     range $k, $v := (index $cfg "env" | default dict) }}
{{-       if kindIs "map" $v }}
{{-         $on := includeTemplate "resolveRef.tmpl" (dict "ref" (printf "@features.%s" (index $v "feature")) "data" $) }}
{{-         if eq $on "true" }}
$lines.Add('  $env:{{ $k }} = "{{ includeTemplate "resolveRef.tmpl" (dict "ref" (index $v "value") "data" $) }}"')
{{-         end }}
{{-       else }}
$lines.Add('  $env:{{ $k }} = "{{ includeTemplate "resolveRef.tmpl" (dict "ref" $v "data" $) }}"')
{{-       end }}
{{-     end }}
{{-     range $p := (index $cfg "path" | default list) }}
$lines.Add('  ifpath_append "{{ includeTemplate "resolveRef.tmpl" (dict "ref" $p "data" $) }}"')
{{-     end }}
{{- /* aliases: PS aliases can't carry arguments, so each becomes a global
       function whose body invokes the resolved command and forwards @args. */ -}}
{{-     range $k, $v := (index $cfg "aliases" | default dict) }}
$lines.Add('  Set-Item -Path function:global:{{ $k }} -Value ([scriptblock]::Create(''{{ includeTemplate "resolveRef.tmpl" (dict "ref" $v "data" $) }} @args''))')
{{-     end }}
{{-     if hasKey $cfg "completion" }}
{{-       $words := splitList " " (index $cfg "completion") }}
$lines.Add('  $__c = cache_completion {{ $name }} {{ range $words }}{{ . }} {{ end }}; if ($__c) { . $__c }')
{{-     end }}
{{-     if hasKey $cfg "setup" }}
$lines.Add('  {{ index $cfg "setup" }}')
{{-     end }}
$lines.Add('} else { dep_mark_missing {{ $name }} }')
{{-     if $gated }}
$lines.Add('}')
{{-     end }}
{{-   end }}
{{- end }}
# dep_report_missing is intentionally NOT emitted here — the profile fires the
# report once, later, after all sourcing (mirrors the unix resolver contract).
Set-Content -LiteralPath $Deps -Value $lines -Encoding utf8

# ---- Output 2 — install-plan.ps1 (topo-sorted install recipe table) ---------
# Purely additive second output: the Kahn topological sort runs IN THIS
# run_onchange pwsh (not in emitted text), because `needs:` edges cross manager
# boundaries and the sort must see one flat node set spanning every manager. The
# Go-template range below only BAKES IN each node's (name, mgr, needs, src); the
# graph walk runs once, here.
#
# SRC (the install identifier/command) is the one field that can contain
# shell-hostile bytes: custom `install:` commands embed quotes, `$`, and pipes.
# Each SRC is baked via a single-quoted here-string (@'...'@) which performs ZERO
# expansion — every byte round-trips verbatim (mirrors the unix quoted-heredoc).
$nodes = @()
{{- range $mgr, $pkgs := .packages }}
{{-   range $name, $cfg := $pkgs }}
{{-     $needsList := index $cfg "needs" | default list }}
{{- /* src per manager (mirrors the unix src mapping): winget/cargo/npm read
       id/source and default to the tool name; custom reads install (default ""). */ -}}
{{-     $src := "" }}
{{-     if eq $mgr "winget" }}{{ $src = index $cfg "id" | default $name }}
{{-     else if eq $mgr "cargo" }}{{ $src = index $cfg "source" | default $name }}
{{-     else if eq $mgr "npm" }}{{ $src = index $cfg "source" | default $name }}
{{-     else if eq $mgr "custom" }}{{ $src = index $cfg "install" | default "" }}
{{-     end }}
$__needs = @({{ range $i, $d := $needsList }}{{ if $i }}, {{ end }}'{{ $d }}'{{ end }})
$__src = @'
{{ $src }}
'@
$nodes += @{ name = '{{ $name }}'; mgr = '{{ $mgr }}'; needs = $__needs; src = $__src }
{{-   end }}
{{- end }}

# ---- Kahn topological sort (needs-before-dependent) ----
# Edge b -> a means "a needs b", i.e. b must be sorted before a.
$indegree = @{}
$succ = @{}
$byName = @{}
foreach ($n in $nodes) {
    $indegree[$n.name] = 0
    $succ[$n.name] = @()
    $byName[$n.name] = $n
}
foreach ($n in $nodes) {
    foreach ($dep in $n.needs) {
        if (-not $indegree.ContainsKey($dep)) {
            throw "install-plan: '$($n.name)' needs unknown tool '$dep'"
        }
        $indegree[$n.name] = $indegree[$n.name] + 1
        $succ[$dep] = $succ[$dep] + $n.name
    }
}
$sorted = @()
# Within a topo level, pick ready nodes in name-sorted order for byte-stable
# output (this file is run_onchange-hashed; nondeterministic output would re-fire).
$ready = @($nodes | Where-Object { $indegree[$_.name] -eq 0 } | ForEach-Object { $_.name } | Sort-Object)
while ($ready.Count -gt 0) {
    $cur = $ready[0]
    $ready = @($ready | Select-Object -Skip 1)
    $sorted += $cur
    $newlyReady = @()
    foreach ($s in $succ[$cur]) {
        $indegree[$s] = $indegree[$s] - 1
        if ($indegree[$s] -eq 0) { $newlyReady += $s }
    }
    if ($newlyReady.Count -gt 0) {
        $ready = @(@($ready) + $newlyReady | Sort-Object)
    }
}
if ($sorted.Count -ne $nodes.Count) {
    # Cycle: some nodes never reached indegree 0 — an author bug in the manifest
    # (cyclic needs graph). Hard-fail apply (non-zero exit), naming the culprits.
    $sortedSet = @{}
    foreach ($s in $sorted) { $sortedSet[$s] = $true }
    $cycle = @($nodes | Where-Object { -not $sortedSet.ContainsKey($_.name) } | ForEach-Object { $_.name })
    throw "install-plan: dependency cycle detected among: $($cycle -join ' ')"
}

$planLines = [System.Collections.Generic.List[string]]::new()
$planLines.Add('# GENERATED by run_onchange_resolve-deps — do not edit. Read by the provisioner.')
$planLines.Add("# format: <name>`t<manager>`t<source-or-install-command>   (topological order)")
foreach ($name in $sorted) {
    $n = $byName[$name]
    $planLines.Add("$($n.name)`t$($n.mgr)`t$($n.src)")
}
Set-Content -LiteralPath $Plan -Value $planLines -Encoding utf8
