{{/* windows/run_onchange_register-winnat-reset-task.ps1.tmpl - apply-time registrar
     for the "reset winnat on UDP ephemeral-port exhaustion" self-heal.

     Problem it fixes: on machines running the Hyper-V host-networking stack
     (Docker Desktop + WSL2), winnat/HNS progressively reserves ephemeral UDP/TCP
     port blocks over uptime and never releases them, until the 49152-65535 pool is
     exhausted -> System log Tcpip Event 4266, which intermittently breaks DNS,
     QUIC/HTTP3, and VPNs. This registers a SYSTEM scheduled task triggered on 4266
     that cycles winnat to flush its reserved-port pool (winnat has no dependent
     services, so the blast radius is a ~1-2s NAT blip that Docker/ICS/WSL recover
     from automatically; userspace-WireGuard VPNs like Tailscale are unaffected).

     Mechanics (mirrors the resolve-deps idiom): the whole task XML + the feature
     flag are baked into the rendered output below, so ANY change to them alters
     this file's rendered content and re-fires run_onchange. Registering a SYSTEM
     task needs admin, so the script self-elevates once (UAC) when not already
     elevated; it only prompts when the rendered content actually changes, not on
     every apply. On UAC decline / failure it exits non-zero so chezmoi retries on
     the next apply (an unchanged run_onchange would otherwise not re-run).

     The feature flag drives BOTH directions: default-on registers; flip it off in
     the private data overlay and the next apply unregisters the task. */}}
# feature flag baked as text so toggling it re-fires run_onchange:
$Desired  = {{ if .features.windows.winnatPortResetTask }}$true{{ else }}$false{{ end }}
$TaskName = 'Winnat-Reset-on-UDP-Port-Exhaustion'

# Task definition. Action guards on winnat existing, so registering on a machine
# without the NAT stack is harmless (the trigger never fires there anyway).
$Xml = @'
<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Self-heal for Tcpip Event 4266 (UDP ephemeral-port exhaustion). Hyper-V/WSL2/Docker winnat progressively reserves ephemeral UDP/TCP port blocks over uptime until the pool is exhausted. On each 4266, cycle the winnat service to flush its reserved-port pool. winnat has no dependent services, so the blast radius is a ~1-2s NAT blip (Docker published ports, ICS, WSL localhost forwarding re-establish automatically). Userspace-WireGuard VPNs (e.g. Tailscale) are unaffected.</Description>
  </RegistrationInfo>
  <Triggers>
    <EventTrigger>
      <Enabled>true</Enabled>
      <Subscription>&lt;QueryList&gt;&lt;Query Id="0" Path="System"&gt;&lt;Select Path="System"&gt;*[System[Provider[@Name='Tcpip'] and (EventID=4266)]]&lt;/Select&gt;&lt;/Query&gt;&lt;/QueryList&gt;</Subscription>
    </EventTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <UserId>S-1-5-18</UserId>
      <RunLevel>HighestAvailable</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT2M</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-NonInteractive -NoProfile -WindowStyle Hidden -Command "if (Get-Service winnat -ErrorAction SilentlyContinue) { Restart-Service winnat -Force }"</Arguments>
    </Exec>
  </Actions>
</Task>
'@

# --- elevation guard: registering/unregistering a SYSTEM task requires admin -----
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltinRole]::Administrator)
if (-not $isAdmin) {
    # Re-run THIS rendered script elevated, using the same interpreter chezmoi
    # invoked us with. Wait, then mirror the child's exit code so a decline/failure
    # leaves run_onchange un-recorded and chezmoi retries next apply.
    $interp = (Get-Process -Id $PID).Path
    $self   = $PSCommandPath
    try {
        $p = Start-Process -FilePath $interp -Verb RunAs -Wait -PassThru `
             -ArgumentList @('-NoProfile','-ExecutionPolicy','Bypass','-File', $self)
        exit $p.ExitCode
    } catch {
        Write-Error "winnat-reset task: elevation declined or failed - $($_.Exception.Message). Re-run 'chezmoi apply' and approve the UAC prompt."
        exit 1
    }
}

# --- elevated body: converge the task to the desired state -----------------------
try {
    $existing = Get-ScheduledTask -TaskName $TaskName -ErrorAction SilentlyContinue
    if ($Desired) {
        Register-ScheduledTask -TaskName $TaskName -Xml $Xml -Force | Out-Null
        Write-Host "winnat-reset task: registered '$TaskName' (fires on Tcpip Event 4266)."
    } elseif ($existing) {
        Unregister-ScheduledTask -TaskName $TaskName -Confirm:$false
        Write-Host "winnat-reset task: feature disabled - unregistered '$TaskName'."
    } else {
        Write-Host "winnat-reset task: feature disabled and task absent - nothing to do."
    }
    exit 0
} catch {
    Write-Error "winnat-reset task: converge failed - $($_.Exception.Message)"
    exit 1
}
