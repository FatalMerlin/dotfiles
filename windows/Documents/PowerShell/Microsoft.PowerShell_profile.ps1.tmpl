function Add-EnvPath {
    param (
        [string] $newPath
    )
    if (($env:Path.Split(";") -contains $newPath)) {
        Write-Host "Path '$newPath' already exists in PATH."
        return
    }
    Write-Host "Adding '$newPath' to PATH."
    $currentPath = [System.Environment]::GetEnvironmentVariable("Path", [System.EnvironmentVariableTarget]::User)
    [System.Environment]::SetEnvironmentVariable("Path", "$currentPath;$newPath", [System.EnvironmentVariableTarget]::User)

    Update-SessionEnvironment # chocolatey function to update current session environment (function aliased by `refreshenv`)
}

function Get-EnvPath {
    [OutputType([string])]
    param(
        [System.EnvironmentVariableTarget] $scope = [System.EnvironmentVariableTarget]::User
    )
    [System.Environment]::GetEnvironmentVariable("Path", $scope).Split(";") | Where-Object { $_ -ne "" }
}

function CleanEnvPath {
    param(
        [System.EnvironmentVariableTarget] $scope = [System.EnvironmentVariableTarget]::User
    )

    Write-Output "Cleaning PATH variable in scope: $scope ..."

    $originalPaths = [System.Environment]::GetEnvironmentVariable("Path", $scope).Split(";") | Where-Object { $_ -ne "" } | Sort-Object
    $newPaths = $originalPaths # unchanged by default
    
    Write-Output "Deduplicating PATH entries..."
    $uniquePaths = $newPaths | Select-Object -Unique
    $diff = Compare-Object -ReferenceObject $newPaths -DifferenceObject $uniquePaths
    $diff | Out-String

    # prompt user to confirm changes, default to Yes
    if ($null -ne $diff) {
        $confirmation = Read-Host "Do you want to apply these changes? (Y/n)"
        if ($confirmation -eq "" -or $confirmation.ToLower() -eq "y") {
            $newPaths = $uniquePaths
            [System.Environment]::SetEnvironmentVariable("Path", $newPaths -join ";", $scope)
        }
    }

    Write-Output "Checking for non-existent PATH entries..."
    $validPaths = $newPaths | Where-Object { Test-Path -Path "$_" -PathType Container }
    $diff = Compare-Object -ReferenceObject $newPaths -DifferenceObject $validPaths
    $diff | Out-String

    if ($null -ne $diff) {
        # prompt user to confirm changes, default to Yes
        $confirmation = Read-Host "Do you want to apply these changes? (Y/n)"
        if ($confirmation -eq "" -or $confirmation.ToLower() -eq "y") {
            $newPaths = $validPaths
            [System.Environment]::SetEnvironmentVariable("Path", $newPaths -join ";", $scope)
        }
    }

    Write-Output "Updating session environment..."
    Update-SessionEnvironment
    $originalPathLength = ($originalPaths).Length
    $finalPathLength = ([System.Environment]::GetEnvironmentVariable("Path", $scope).Split(";") | Where-Object { $_ -ne "" }).Length
    Write-Output "PATH cleaned: $originalPathLength -> $finalPathLength entries."
    Write-Output "Done"
}

function Get-ImageDimension {
    param (
        [Parameter(Mandatory = $true)]
        [System.IO.FileInfo]$ImagePath
    )

    $ImagePath = (Resolve-Path $ImagePath).Path

    if (-not $ImagePath.Exists) {
        Write-Error "Image file does not exist: $($ImagePath.FullName)"
        return
    }

    $identifyOutput = magick.exe identify -ping -format '%w:%h' "$($ImagePath.FullName)"
    $dimensions = $identifyOutput -split ":"
    if ($dimensions.Length -ne 2) {
        Write-Error "Failed to get image dimensions for $($ImagePath.FullName). Output: $identifyOutput"
        return
    }
    return [int]$dimensions[0], [int]$dimensions[1]
}

function square {
    param (
        [Parameter(Mandatory = $true)]
        [System.IO.FileInfo]$InputPath,
        [Parameter()]
        [int]$Size,
        [Parameter()]
        [System.IO.FileInfo]$OutputPath
    )

    $ErrorActionPreference = "Stop"

    $InputPath = (Resolve-Path $InputPath).Path
    if (-not $InputPath.Exists) {
        Write-Error "Input file does not exist: $($InputPath.FullName)"
        return
    }

    if (-not $Size) {
        $Dimensions = Get-ImageDimension -ImagePath $InputPath
        $Size = [Math]::Max($Dimensions[0], $Dimensions[1])
    }

    if (-not $OutputPath) {
        $OutputPath = [System.IO.FileInfo]::new("$($InputPath.Directory)\$($InputPath.BaseName).$Size$($InputPath.Extension)")
    }

    if ($OutputPath.Exists) {
        Write-Host "Output file already exists: $($OutputPath.FullName)"
        return
    }
    
    magick.exe -background none -gravity center $InputPath.FullName -resize ${Size}x${Size} -extent ${Size}x${Size} $OutputPath.FullName
}

function which {
    param (
        [string] $command
    )
    $cmd = Get-Command $command -ErrorAction SilentlyContinue
    return $cmd.Definition
}
