#region Autocompletes
# winget autocomplete
# See: https://learn.microsoft.com/en-us/windows/package-manager/winget/tab-completion
# Reconstructs from CommandElements (not ToString) so alias-injected CommandAst nodes work correctly,
# and appends a trailing space when no word is being typed so winget knows to complete the next argument.
$__wingetCompleterBlock = {
    param($wordToComplete, $commandAst, $cursorPosition)
    [Console]::InputEncoding = [Console]::OutputEncoding = $OutputEncoding = [System.Text.Utf8Encoding]::new()
    $Local:word = $wordToComplete.Replace('"', '""')
    $Local:parts = $commandAst.CommandElements | ForEach-Object { $_.ToString() }
    $Local:cmdStr = ($Local:parts -join ' ') + $(if (-not $wordToComplete) { ' ' } else { '' })
    winget complete --word="$Local:word" --commandline "$($Local:cmdStr.Replace('"', '""'))" --position $Local:cmdStr.Length | ForEach-Object {
        [System.Management.Automation.CompletionResult]::new($_, $_, 'ParameterValue', $_)
    }
}
Register-ArgumentCompleter -Native -CommandName winget -ScriptBlock $__wingetCompleterBlock
#endregion

# Creates a named function that calls $Command with fixed $AliasArgs prepended, and wires tab
# completion by injecting those alias args into the base command's completer block AST.
# The base completer is discovered by convention: __${Command}CompleterBlock.
function New-CommandAlias {
    param(
        [string]   $Name,
        [string]   $Command,
        [string[]] $AliasArgs = @()
    )
    Remove-Item "alias:$Name" -Force -ErrorAction SilentlyContinue
    Set-Item -Path "function:global:$Name" -Value { & $Command @AliasArgs @args }.GetNewClosure()

    $baseCompleter = Get-Variable "__${Command}CompleterBlock" -ValueOnly -ErrorAction SilentlyContinue
    if (-not $baseCompleter) { return }

    Register-ArgumentCompleter -CommandName $Name -ScriptBlock {
        param($wordToComplete, $commandAst, $cursorPosition)
        $userArgs = $commandAst.CommandElements | Select-Object -Skip 1 | ForEach-Object { $_.ToString() }
        $newCmd = (@($Command) + @($AliasArgs) + @($userArgs)) -join ' '
        $scriptAst = [System.Management.Automation.Language.Parser]::ParseInput($newCmd, [ref]$null, [ref]$null)
        $newCmdAst = $scriptAst.EndBlock.Statements[0].PipelineElements[0]
        & $baseCompleter $wordToComplete $newCmdAst $newCmd.Length
    }.GetNewClosure()
}

