# (n)ano (s)sh (c)onfig (p)ersonal — watch-edit the personal SSH host inventory, applying
# on every save. $env:EDITOR is scoped to this call only (mirrors the unix alias's
# one-shot `EDITOR=nano cmd` prefix instead of flipping the session's default editor).
function nscp {
    $prevEditor = $env:EDITOR
    $env:EDITOR = "nano"
    try { chezmoi edit --watch -S "$DOTFILES_PRIV_SRC\personal" "$HOME\.ssh\config.d\personal.conf" }
    finally { $env:EDITOR = $prevEditor }
}

# (c)hezmoi (s)sh (c)onfig (p)ersonal — same, with $EDITOR left at its default
function cscp { chezmoi edit --watch -S "$DOTFILES_PRIV_SRC\personal" "$HOME\.ssh\config.d\personal.conf" }

# Re-adopt ~/.ssh/config.d/personal.conf into the personal source after editing the live
# file directly (rather than through cscp/nscp) — pulls its current on-disk content back
# into the chezmoi source state.
function sshadopt { chezmoi add -S "$DOTFILES_PRIV_SRC\personal" "$HOME\.ssh\config.d\personal.conf" }

