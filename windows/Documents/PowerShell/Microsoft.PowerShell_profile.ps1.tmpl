        [CmdletBinding()]
        $inputObject
    )
    Select-String -pattern $pattern -InputObject $input
}

function mp4towebm {
    [CmdletBinding()]
    param (
        [Parameter(Mandatory = $true)]
        [System.IO.FileInfo]
        $InputPath,

        [Parameter()]
        [System.IO.FileInfo]
        $OutputPath,

        # See: https://superuser.com/a/677580/685008
        [Parameter()]
        [ValidateRange(4, 63)]
        [byte]
        $Crf = 30,

        [Parameter()]
        [switch]
        $RemoveAudio = $false
    )

    if (-not $OutputPath) {
        [System.IO.FileInfo] $OutputPath = Join-Path $InputPath.Directory "$($InputPath.BaseName).webm"
    }

    if ($RemoveAudio) {
        $AudioFlag = "-an"
    }
    else {
        $AudioFlag = "-b:a 128k -c:a libopus".Split(" ")
    }

    # See: https://stackoverflow.com/a/47512301/4161937
    & ffmpeg -y -i "$InputPath" -c:v libvpx-vp9 -deadline realtime -crf $Crf -b:v 0 $AudioFlag "$OutputPath"
}

