function EnsureExperimentalFeature {
    param (
        [string] $FeatureName
    )
    $feature = Get-ExperimentalFeature -Name $FeatureName
    if (-not ($feature.Enabled)) {
        Write-Host "Enabling experimental PowerShell feature: $FeatureName"
        Enable-ExperimentalFeature -Name $FeatureName
    }
}

function EnsurePSResource {
    param (
        [string] $Name
    )
    # If Stdout is redirected, the condition always returns $true, so use -ErrorAction to suppress errors
    if (-not (Get-PSResource -Name $Name -ErrorAction SilentlyContinue)) {
        Install-PSResource -Name $Name -Scope CurrentUser
    }
    Import-Module $Name
}
#endregion

