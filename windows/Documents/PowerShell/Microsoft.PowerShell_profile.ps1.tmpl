#region Dependency management — declarative manifest engine
# run_onchange_resolve-deps.ps1 renders .chezmoidata/packages.yaml into
# ~/.config/dotfiles/deps.ps1 at apply-time. Dot-source it at TOP LEVEL so its
# env / alias / PATH / completion wiring lands in the global session scope (a
# module function could not reach global). Then load the provisioner (im/lm),
# register the rustup manager bootstrap recipe (cargo isn't a manifest tool),
# and fire a single missing-report covering deps.ps1 guards + the recipe.
$DepsArtifact = "$HOME/.config/dotfiles/deps.ps1"
if (Test-Path $DepsArtifact) { . $DepsArtifact }
Import-Module "$HOME/Documents/PowerShell/dotfiles/lib/Provisioner.psm1" -Force
Add-DepRecipe cargo winget Rustlang.Rustup
dep_report_missing
#endregion

function grep {
