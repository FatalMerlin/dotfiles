# Interactive search-and-install: fuzzy-pick from Find-WinGetPackage results, then install the selection.
# Uses Select-Object Id, Name only — accessing Version or AvailableVersions triggers a per-package
# catalog lookup and makes the whole call slow. Same applies to Get-WinGetPackage (inherently ~3.7s),
# so both queries run in parallel via Start-ThreadJob: total wait ≈ max(3.7s, 1.5s) vs 5.2s sequential.
function wgsi {
    param([string] $query)

    if (-not (Get-Command fzf -ErrorAction SilentlyContinue)) {
        Write-Error "fzf is not installed. Run: wgi junegunn.fzf"
        return
    }

    $installedJob = Start-ThreadJob { Get-WinGetPackage | Select-Object -ExpandProperty Id }
    $searchJob = Start-ThreadJob {
        Find-WinGetPackage -Source winget -Query $using:query -MatchOption ContainsCaseInsensitive |
        Select-Object Id, Name
    }

    Write-Progress -Id 0 -Activity 'wgsi' -Status 'Searching...' -PercentComplete -1
    $null = Wait-Job $installedJob, $searchJob
    Write-Progress -Id 0 -Activity 'wgsi' -Completed

    $installedIds = [System.Collections.Generic.HashSet[string]]::new(
        [string[]] (Receive-Job $installedJob -ErrorAction Stop),
        [System.StringComparer]::OrdinalIgnoreCase
    )
    $results = Receive-Job $searchJob -ErrorAction Stop |
    Where-Object { -not $installedIds.Contains($_.Id) }
    Remove-Job $installedJob, $searchJob

    if (-not $results) { Write-Warning "No results for '$query' (or all matches already installed)."; return }

    # Prepend Id as a hidden field (before \t) so fzf displays "Name  (Id)" but we recover the exact Id.
    $fzfInput = $results | ForEach-Object { "$($_.Id)`t$($_.Name)  ($($_.Id))" }
    $selected = $fzfInput | fzf --delimiter "`t" --with-nth 2 --layout reverse
    if (-not $selected) { return }

    $pkgId = ($selected -split "`t", 2)[0]
    Write-Host "Installing: $pkgId" -ForegroundColor Cyan
    wgi $pkgId
}
