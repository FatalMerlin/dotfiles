BREW=/home/linuxbrew/.linuxbrew/bin/brew

if ifalias brew brew custom '/bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"' \
    /home/linuxbrew/.linuxbrew/bin/brew; then

    debug_measure_start "brew: shellenv"
    if [ -z "$HOMEBREW_PREFIX" ]; then
        _brew_shellenv="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/completions/brew-shellenv"
        if [[ ! -f "$_brew_shellenv" || "$BREW" -nt "$_brew_shellenv" ]]; then
            mkdir -p "${_brew_shellenv:h}"
            # brew needs tools like dirname and readlink; set only for the subprocess
            PATH=/usr/bin "$BREW" shellenv > "$_brew_shellenv" 2>/dev/null
        fi
        source "$_brew_shellenv"
        unset _brew_shellenv
    fi
    debug_measure_end

    alias bu="brew upgrade"

    ifalias vkv vkv brew falcosuessgott/tap/vkv
    if ifalias k9s k9s brew derailed/k9s/k9s; then
        export K9S_FEATURE_GATE_NODE_SHELL=true
    fi
    if ifalias k kubectl brew kubectl; then
        export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
        debug_measure_start "brew: krew plugin check"
        _krew_receipts="${KREW_ROOT:-$HOME/.krew}/receipts"
        if [[ ! -d "$_krew_receipts" ]]; then
            echo "'kubectl krew' was missing, installing..."
            (
                set -x
                cd "$(mktemp -d)" &&
                    OS="$(uname | tr '[:upper:]' '[:lower:]')" &&
                    ARCH="$(uname -m | sed -e 's/x86_64/amd64/' -e 's/\(arm\)\(64\)\?.*/\1\2/' -e 's/aarch64$/arm64/')" &&
                    KREW="krew-${OS}_${ARCH}" &&
                    curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/${KREW}.tar.gz" &&
                    tar zxvf "${KREW}.tar.gz" &&
                    ./"${KREW}" install krew
            )
        else
            [[ -f "$_krew_receipts/oidc-login.yaml"  ]] || kubectl krew install oidc-login
            [[ -f "$_krew_receipts/view-secret.yaml" ]] || kubectl krew install view-secret
            [[ -f "$_krew_receipts/node-shell.yaml"  ]] || kubectl krew install node-shell
        fi
        unset _krew_receipts
        debug_measure_end

        if ifcmd helm brew helm; then
          debug_measure_start "brew: helm completions"
          cache_completion helm helm completion zsh
          debug_measure_end
        fi
    fi

    if ifcmd k3d brew k3d; then
      debug_measure_start "brew: k3d completions"
      cache_completion k3d k3d completion zsh
      debug_measure_end
    fi

    if ifcmd fleet brew fleet-cli; then
      debug_measure_start "brew: fleet completions"
      cache_completion fleet fleet completion zsh
      debug_measure_end
    fi

    # Source : https://github.com/FalcoSuessgott/vkv
    # Install: https://falcosuessgott.github.io/vkv/installation/
    if ifcmd vkv brew falcosuessgott/tap/vkv; then
        debug_measure_start "brew: vkv completions"
        cache_completion vkv vkv completion zsh
        debug_measure_end
    fi

    # Source: https://github.com/junegunn/fzf
    # Set up fzf key bindings and fuzzy completion
    if ifcmd fzf brew fzf; then
        debug_measure_start "brew: fzf completions"
        cache_completion fzf fzf --zsh
        debug_measure_end
    fi

    # https://github.com/nvbn/thefuck
    if ifcmd thefuck brew thefuck; then
        debug_measure_start "brew: thefuck alias"
        cache_completion thefuck thefuck --alias
        debug_measure_end
    fi

    # Source: https://kompose.io/installation/
    # Load kompose completion
    if ifcmd kompose brew kompose; then
        debug_measure_start "brew: kompose completions"
        cache_completion kompose kompose completion zsh
        debug_measure_end
    fi

    if ifcmd glab brew glab; then
        # GitLab CLI / `brew install glab`
        # On a work host (hostname suffix from the private channel) point glab at the
        # work GitLab; otherwise leave GITLAB_HOST unset so glab defaults to gitlab.com.
        # (A former hard-coded fallback GitLab was dropped — it is decommissioned;
        # see the S5 git-settings audit.)
        if [[ "$(hostname -f)" == *{{ .linux.work.gitlabHostSuffix }} ]]; then
            export GITLAB_HOST="{{ .linux.work.gitlabHost }}"
        fi
    fi

    ifcmd http brew httpie

    if ifcmd go brew go; then
        export PATH=$PATH:$HOME/go/bin
    fi

    if ifcmd dstask brew dstask; then
      alias task=dstask
      alias t=dstask
    fi

    ifcmd argocd brew argocd
    ifcmd kustomize brew kustomize
    ifcmd jq brew jq
    ifcmd yq brew yq

    # 1Password CLI (op) — resolves op:// secret references (used by the opx wrapper + jira/awx/codex aliases)
    ifcmd op brew 1password-cli

    if ifcmd jiratui brew jiratui; then
      # For all available settings see:
      # https://jiratui.readthedocs.io/en/latest/users/configuration/reference.html#settings
      export JIRA_API_BASE_URL="{{ .linux.work.jira.baseUrl }}"
      export JIRA_API_USERNAME="{{ .linux.work.jira.username }}"
      export JIRA_API_TOKEN="{{ .linux.work.jira.token }}"
      export JIRA_ACCOUNT_ID="{{ .linux.work.jira.accountId }}"

      # the tool complains if it doesn't have a config file
      local jira_config_dir="$HOME/.config/jiratui"
      if ! [ -d "$jira_config_dir" ]; then
        mkdir -p "$jira_config_dir"
      fi

      local jira_config_file="$jira_config_dir/config.yaml"
      if ! [ -f "$jira_config_file" ]; then
        touch "$jira_config_file"
      fi

      alias jira="OP_ACCOUNT={{ .linux.work.opAccount }} opx jiratui ui --jql-expression-id 1" # bug in the tool, config setting for this is ignored
      alias jiratui="OP_ACCOUNT={{ .linux.work.opAccount }} opx jiratui"
    fi

    ifcmd gh brew gh
    ifcmd bun brew oven-sh/bun/bun

    if ifcmd fnm brew fnm; then
        debug_measure_start "brew: fnm init"
        cache_completion fnm fnm env --use-on-cd --shell zsh
        debug_measure_end
        fnm install --use --lts >/dev/null 2>&1
    fi

    ifcmd krr brew robusta-dev/homebrew-krr/krr
    ifcmd hcloud brew hcloud

    # mutagen remote filesystem sync
    ifcmd mutagen brew mutagen-io/mutagen/mutagen

    # lazygit for nvim
    ifcmd lazygit brew jesseduffield/lazygit/lazygit

    # Rust Token Killer (rtk) — dependency tracked; `rtk init -g` intentionally NOT run.
    # It flips rtk into global-hook mode and prompts interactively ("re-enable rtk?") on
    # zsh startup, which breaks automated/agent sessions. RTK context is wired via
    # ~/.claude/env/local-paths.md, not the shell. Re-enable manually if desired:
    #   rtk init -g >/dev/null
    ifcmd rtk brew rtk
fi
