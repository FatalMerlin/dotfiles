BREW=/home/linuxbrew/.linuxbrew/bin/brew

if ifalias brew brew custom '/bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"' \
    /home/linuxbrew/.linuxbrew/bin/brew; then

    debug_measure_start "brew: shellenv"
    if [ -z "$HOMEBREW_PREFIX" ]; then
        _brew_shellenv="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/completions/brew-shellenv"
        if [[ ! -f "$_brew_shellenv" || "$BREW" -nt "$_brew_shellenv" ]]; then
            mkdir -p "${_brew_shellenv:h}"
            # brew needs tools like dirname and readlink; set only for the subprocess
            PATH=/usr/bin "$BREW" shellenv > "$_brew_shellenv" 2>/dev/null
        fi
        source "$_brew_shellenv"
        unset _brew_shellenv
    fi
    debug_measure_end

    alias bu="brew upgrade"

    if ifcmd jiratui brew jiratui; then
      # For all available settings see:
      # https://jiratui.readthedocs.io/en/latest/users/configuration/reference.html#settings
      export JIRA_API_BASE_URL="{{ .linux.work.jira.baseUrl }}"
      export JIRA_API_USERNAME="{{ .linux.work.jira.username }}"
      export JIRA_API_TOKEN="{{ .linux.work.jira.token }}"
      export JIRA_ACCOUNT_ID="{{ .linux.work.jira.accountId }}"

      # the tool complains if it doesn't have a config file
      local jira_config_dir="$HOME/.config/jiratui"
      if ! [ -d "$jira_config_dir" ]; then
        mkdir -p "$jira_config_dir"
      fi

      local jira_config_file="$jira_config_dir/config.yaml"
      if ! [ -f "$jira_config_file" ]; then
        touch "$jira_config_file"
      fi

      alias jira="OP_ACCOUNT={{ .linux.work.opAccount }} opx jiratui ui --jql-expression-id 1" # bug in the tool, config setting for this is ignored
      alias jiratui="OP_ACCOUNT={{ .linux.work.opAccount }} opx jiratui"
    fi
fi
