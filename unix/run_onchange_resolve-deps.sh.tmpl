#!/usr/bin/env -S bash -eEuo pipefail
{{/* prototype/unix/run_onchange_resolve-deps.sh.tmpl — apply-time resolver.
     chezmoi renders this (manifest + private data in scope) and runs the result.
     Regenerates deps.sh + install-plan.sh whenever the manifest changes: the
     whole manifest is baked in below, so any edit changes this file's rendered
     content -> run_onchange re-fires. */}}
# manifest-hash: {{ .packages | toJson | sha256sum }}
# GENERATED-RESOLVER — do not hand-edit the emitted deps.sh.

OUT_DIR="${DEPS_OUT_DIR:-$HOME/.config/dotfiles}"
DEPS="$OUT_DIR/deps.sh"
PLAN="$OUT_DIR/install-plan.sh"
mkdir -p "$OUT_DIR"

{
  printf '%s\n' '# GENERATED by run_onchange_resolve-deps — do not edit. Source only.'
  printf '%s\n' '. "$HOME/.config/dotfiles/lib/core.sh"'
  printf '%s\n' '[ -f "$HOME/.config/dotfiles/hooks/setup-hooks.sh" ] && . "$HOME/.config/dotfiles/hooks/setup-hooks.sh"'
  printf '%s\n\n' 'dep_reset_missing'
{{- range $mgr, $pkgs := .packages }}
{{-   range $name, $cfg := $pkgs }}
  printf '%s\n' '# ---- {{ $name }} ({{ $mgr }}) ----'
{{-     $gate := index $cfg "gate" | default "" }}
{{-     $check := index $cfg "check" | default "command" }}
{{-     $pkg := index $cfg "package" | default $name }}
{{-     $pred := printf "have %s" $name }}
{{-     if eq $check "dpkg" }}{{ $pred = printf "dpkg -s %s >/dev/null 2>&1" $pkg }}
{{-     else if hasPrefix "file:" $check }}{{ $pred = printf "[ -e \"%s\" ]" (trimPrefix "file:" $check) }}
{{-     else if hasPrefix "custom:" $check }}{{ $pred = trimPrefix "custom:" $check }}
{{-     end }}
{{- /* gate is an OUTER skip-wrapper, NOT `gate && pred`: when the gate excludes this
       machine the whole guard (incl. dep_mark_missing) is skipped, so a gated-out tool
       is invisible — never reported missing / offered for install. */ -}}
{{-     $gated := false }}
{{-     if and (kindIs "map" $gate) (hasKey $gate "hostSuffix") }}
{{-       $gated = true }}
  printf '%s\n' 'if [[ "$(hostname -f)" == *{{ includeTemplate "resolveRef.tmpl" (dict "ref" (index $gate "hostSuffix") "data" $) }} ]]; then'
{{-     else if eq (printf "%v" $gate) "!wsl" }}
{{-       $gated = true }}
  printf '%s\n' 'if [ "${IS_WSL:-0}" != "1" ]; then'
{{-     else if eq (printf "%v" $gate) "wsl" }}
{{-       $gated = true }}
  printf '%s\n' 'if [ "${IS_WSL:-0}" = "1" ]; then'
{{-     end }}
  printf '%s\n' 'if {{ $pred }}; then'
{{- /* env value is either a plain string (always exported) or a map
       { value, feature } — a per-host FEATURE-gated export: emitted only when
       .features.<feature> is true for this host (resolved at apply-time). The
       tool itself stays tracked everywhere; only the work-specific env toggles
       per host. Feature flags default false in the public defaults.yaml and are
       flipped true per host from the private [data] channel. */ -}}
{{-     range $k, $v := (index $cfg "env" | default dict) }}
{{-       if kindIs "map" $v }}
{{-         $on := includeTemplate "resolveRef.tmpl" (dict "ref" (printf "@features.%s" (index $v "feature")) "data" $) }}
{{-         if eq $on "true" }}
  printf '%s\n' '  export {{ $k }}="{{ includeTemplate "resolveRef.tmpl" (dict "ref" (index $v "value") "data" $) }}"'
{{-         end }}
{{-       else }}
  printf '%s\n' '  export {{ $k }}="{{ includeTemplate "resolveRef.tmpl" (dict "ref" $v "data" $) }}"'
{{-       end }}
{{-     end }}
{{-     range $p := (index $cfg "path" | default list) }}
  printf '%s\n' '  ifpath_append "{{ includeTemplate "resolveRef.tmpl" (dict "ref" $p "data" $) }}"'
{{-     end }}
{{-     range $k, $v := (index $cfg "aliases" | default dict) }}
  printf '%s\n' '  alias {{ $k }}="{{ includeTemplate "resolveRef.tmpl" (dict "ref" $v "data" $) }}"'
{{-     end }}
{{-     if hasKey $cfg "completion" }}
{{-       $words := splitList " " (index $cfg "completion") }}
  printf '%s\n' '  cache_completion {{ $name }} {{ range $words }}{{ . }} {{ end }}'
{{-     end }}
{{-     if hasKey $cfg "setup" }}
  printf '%s\n' '  {{ index $cfg "setup" }}'
{{-     end }}
  printf '%s\n' '  :'
  printf '%s\n' 'else dep_mark_missing {{ $name }}; fi'
{{-     if $gated }}
  printf '%s\n' 'fi'
{{-     end }}
{{- end }}
{{- end }}
{{/* dep_report_missing is intentionally NOT emitted here anymore: the legacy
     dependencies/*.zsh bootstraps (brew/rustup MANAGER installs + jiratui)
     run AFTER deps.sh is sourced (dot_aliases.zsh.tmpl) and add to the SAME
     _DEP_MISSING_* tally via the re-plumbed ifcmd/ifpkg/ifalias in
     dot_functions.zsh. Reporting here would fire before those bootstraps
     ever run, missing them entirely. The report now fires exactly once,
     from dot_zshrc.tmpl, after ALL sourcing (manifest deps.sh AND the
     legacy bootstraps) — see the `dep_report_missing` call there. */}}
} > "$DEPS"

{{/* ---- install-plan.sh: topo-sorted install recipe table (Task 20a) --------
     Purely ADDITIVE second output of this same resolver run: does not touch
     the deps.sh block above. Consumed later by the on-demand provisioner
     (`im`, a separate task) as `<name>\t<manager>\t<source-or-install-cmd>`
     rows in needs-before-dependent order.

     Unlike the deps.sh block (which is entirely `printf`'d TEXT written into
     a file), the statements below are LITERAL BASH that the resolver script
     itself executes at apply-time, building real bash arrays and running a
     real Kahn topological sort — not text destined for a file. This is
     required because `needs:` edges cross manager boundaries (e.g. brew's
     `helm` needs brew's `kubectl`; cargo's `sccache` needs apt's
     `libssl-dev` and `pkg-config`), so the sort must see one flat node set
     spanning every manager: the Go template's `range` below just BAKES IN
     each node's (manager, SRC, needs-list) as array-assignment statements;
     the loop that actually walks the graph runs once, in the emitted bash.

     SRC (the install identifier/command) is the one field that can contain
     shell-hostile bytes: custom `install:` commands embed quotes, `$`,
     pipes, and even literal single quotes (e.g. the ail-cli manifest entry's
     `sed -e 's/x86_64/amd64/'`), so it cannot be safely bash-single-quoted
     at template-render time. Instead each SRC is written into the emitted
     bash via a quoted heredoc (`<<'_DOTFILES_SRC_EOF'`), which performs zero
     expansion — every byte round-trips verbatim regardless of quoting.
     `name` and `mgr` are manifest map keys (plain identifiers, no spaces/
     quotes in practice) so a plain literal bash single-quote wrap is
     sufficient for them and for the space-separated `needs` list (itself a
     list of such keys, built by hand below rather than via sprig `join` to
     keep this template's function surface identical to the rest of the file
     — only `index`/`default`/`eq`/`range` etc. already proven elsewhere here). */}}
declare -a _dp_nodes=()
declare -A _dp_mgr=() _dp_needs=() _dp_src=()
{{- range $mgr, $pkgs := .packages }}
{{-   range $name, $cfg := $pkgs }}
{{-     $needsList := index $cfg "needs" | default list }}
{{-     $needsStr := "" }}
{{-     range $i, $dep := $needsList }}
{{-       if eq $i 0 }}{{ $needsStr = $dep }}
{{-       else }}{{ $needsStr = printf "%s %s" $needsStr $dep }}
{{-       end }}
{{-     end }}
{{-     $src := "" }}
{{-     if eq $mgr "apt" }}{{ $src = index $cfg "package" | default $name }}
{{-     else if eq $mgr "brew" }}{{ $src = index $cfg "source" | default $name }}
{{-     else if eq $mgr "cargo" }}{{ $src = index $cfg "source" | default $name }}
{{-     else if eq $mgr "custom" }}{{ $src = index $cfg "install" | default "" }}
{{-     end }}
_dp_nodes+=('{{ $name }}')
_dp_mgr['{{ $name }}']='{{ $mgr }}'
_dp_needs['{{ $name }}']='{{ $needsStr }}'
_dp_src['{{ $name }}']="$(cat <<'_DOTFILES_SRC_EOF'
{{ $src }}
_DOTFILES_SRC_EOF
)"
{{-   end }}
{{- end }}

# ---- Kahn topological sort (needs-before-dependent) ----
# Edge b -> a means "a needs b", i.e. b must be installed (sorted) before a.
declare -A _dp_indegree=() _dp_succ=()
for _dp_n in "${_dp_nodes[@]}"; do
  : "${_dp_indegree[$_dp_n]:=0}"
  : "${_dp_succ[$_dp_n]:=}"
done
for _dp_n in "${_dp_nodes[@]}"; do
  for _dp_dep in ${_dp_needs[$_dp_n]:-}; do
    if [ -z "${_dp_indegree[$_dp_dep]+x}" ]; then
      echo "install-plan: '$_dp_n' needs unknown tool '$_dp_dep' (not in manifest)" >&2
      exit 1
    fi
    _dp_indegree[$_dp_n]=$(( _dp_indegree[$_dp_n] + 1 ))
    _dp_succ[$_dp_dep]="${_dp_succ[$_dp_dep]:+${_dp_succ[$_dp_dep]} }$_dp_n"
  done
done
declare -a _dp_sorted=() _dp_ready=()
for _dp_n in "${_dp_nodes[@]}"; do [ "${_dp_indegree[$_dp_n]}" -eq 0 ] && _dp_ready+=("$_dp_n"); done
while [ "${#_dp_ready[@]}" -gt 0 ]; do
  # Stable order within a topo level: sort the current ready set by name so
  # repeated renders of the same manifest are byte-identical (this file is
  # run_onchange-hashed; nondeterministic output would re-fire needlessly).
  IFS=$'\n' _dp_ready=($(printf '%s\n' "${_dp_ready[@]}" | sort)); unset IFS
  _dp_cur="${_dp_ready[0]}"; _dp_ready=("${_dp_ready[@]:1}")
  _dp_sorted+=("$_dp_cur")
  for _dp_s in ${_dp_succ[$_dp_cur]:-}; do
    _dp_indegree[$_dp_s]=$(( _dp_indegree[$_dp_s] - 1 ))
    [ "${_dp_indegree[$_dp_s]}" -eq 0 ] && _dp_ready+=("$_dp_s")
  done
done
if [ "${#_dp_sorted[@]}" -ne "${#_dp_nodes[@]}" ]; then
  # Cycle: some nodes never reached indegree 0. This is an author bug in the
  # manifest (a cyclic `needs:` graph) — hard-fail apply, naming the culprits.
  # NOTE: this fatality is scoped to plan-emission/cycle-detection only; the
  # later `im` provisioner's actual package INSTALLATION is non-fatal per-tool.
  declare -A _dp_sorted_set=()
  for _dp_n in "${_dp_sorted[@]}"; do _dp_sorted_set[$_dp_n]=1; done
  declare -a _dp_cycle=()
  for _dp_n in "${_dp_nodes[@]}"; do [ -z "${_dp_sorted_set[$_dp_n]+x}" ] && _dp_cycle+=("$_dp_n"); done
  echo "install-plan: dependency cycle detected among: ${_dp_cycle[*]}" >&2
  exit 1
fi

{
  printf '%s\n' '# GENERATED by run_onchange_resolve-deps — do not edit. Read by im (provisioner).'
  printf '%s\n' '# format: <name>\t<manager>\t<source-or-install-command>   (topological order)'
  for _dp_n in "${_dp_sorted[@]}"; do
    printf '%s\t%s\t%s\n' "$_dp_n" "${_dp_mgr[$_dp_n]}" "${_dp_src[$_dp_n]}"
  done
} > "$PLAN"
